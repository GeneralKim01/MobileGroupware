<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 전체 화면(툴바 + 본문 + 하단바) -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ✅ 우리가 직접 쓰는 툴바(액션바 대체) -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            android:titleTextColor="@android:color/white"
            android:title="동신툴피아 그룹웨어" />

        <!-- 본문 컨테이너 (여기엔 top padding 절대 주지 말 것) -->
        <FrameLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#ffffff">

            <WebView
                android:id="@+id/webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false" />

            <!-- ✅ 위치 저장용(보이지 않게) -->
            <WebView
                android:id="@+id/webviewLo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </FrameLayout>

        <!-- ✅ 하단 버튼바 -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:background="@android:color/transparent">

            <ImageButton
                android:id="@+id/Button1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg3"
                android:src="@drawable/btn1_icon_home"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />

            <ImageButton
                android:id="@+id/Button2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg3"
                android:src="@drawable/btn2_icon_pre"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />

            <ImageButton
                android:id="@+id/Button3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg3"
                android:src="@drawable/btn3_icon_next"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />

            <ImageButton
                android:id="@+id/Button4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg3"
                android:src="@drawable/btn4_icon_refresh"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />

            <ImageButton
                android:id="@+id/Button4_LOC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg3"
                android:src="@drawable/btn5_icon_location"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />

            <ImageButton
                android:id="@+id/Button9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg3"
                android:src="@drawable/btn6_icon_logout"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ✅ 팝업 WebView 오버레이 (맨 위 덮기) -->
    <FrameLayout
        android:id="@+id/popupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>